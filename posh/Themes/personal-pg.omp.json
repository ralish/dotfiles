{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "version": 4,
    "patch_pwsh_bleed": true,
    "final_space": true,
    "console_title_template": "{{if .Root}}root :: {{end}}{{.Shell}} :: {{.Folder}}",
    "transient_prompt": {
        "template": " ~#@\u276f ",
        "background": "transparent",
        "foreground": "#7A7A7A"
    },
    "blocks": [
        {
            "type": "prompt",
            "alignment": "left",
            "segments": [
                {
                    "type": "os",
                    "style": "diamond",
                    "leading_diamond": "\ue0c7\u2593",
                    "template": " {{ if .WSL }}\uf17c on {{ end }}{{ .Icon }}<#7A7A7A> \ue0b1</>",
                    "background": "#2F2F2F",
                    "foreground": "#26C6DA",
                    "cache": {
                        "duration": "infinite",
                        "strategy": "session"
                    }
                },
                {
                    "type": "root",
                    "style": "diamond",
                    "template": " \uf0e7<#7A7A7A> \ue0b1</>",
                    "background": "#2F2F2F",
                    "foreground": "#FFFF66"
                },
                {
                    "type": "session",
                    "style": "diamond",
                    "template": " {{ if ne .Env.POSH_SESSION_DEFAULT_USER .UserName }}<#77F5D6>{{ .UserName }}</><#7A7A7A>@</>{{ end }}<#2EEFBF>{{ .HostName }}</><#7A7A7A> \ue0b1</>",
                    "background": "#2F2F2F",
                    "foreground": "#FAFAFA"
                },
                {
                    "type": "path",
                    "style": "diamond",
                    "template": "<#F2F200> \ue5ff </>{{ .Path }} ",
                    "background": "#2F2F2F",
                    "foreground": "#FAFAFA",
                    "options": {
                        "style": "agnoster_short",
                        "home_icon": "\uf015",
                        "folder_icon": "<#B5B2C2>\ue5fe </>",
                        "folder_separator_icon": "<#B5B2C2>\ue0bf </>"
                    }
                },
                {
                    "type": "git",
                    "style": "diamond",
                    "template": "<#7A7A7A>\ue0b1 </>{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}<#E84855> \uf044 {{ .Working.String }}</>{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#2FDA4E> \uf046 {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
                    "background": "#2F2F2F",
                    "foreground": "#FFEB3B",
                    "foreground_templates": [
                        "{{ if or (.Working.Changed) (.Staging.Changed) }}#FFEB3B{{ end }}",
                        "{{ if gt .Ahead 0 }}#2EC4B6{{ end }}",
                        "{{ if gt .Behind 0 }}#8A4FFF{{ end }}"
                    ],
                    "options": {
                        "fetch_status": true,
                        "fetch_push_status": true,
                        "fetch_upstream_icon": true,
                        "source": "pwsh"
                    }
                },
                {
                    "type": "text",
                    "style": "diamond",
                    "trailing_diamond": "\ue0b0",
                    "background": "#2F2F2F",
                    "foreground": "#FAFAFA"
                }
            ]
        },
        {
            "type": "prompt",
            "alignment": "right",
            "segments": [
                {
                    "type": "text",
                    "style": "diamond",
                    "leading_diamond": "\ue0b2",
                    "background": "#2F2F2F",
                    "foreground": "#FAFAFA"
                },
                {
                    "type": "dotnet",
                    "style": "diamond",
                    "template": " \ue77f {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }}<#7A7A7A> \ue0b3</>",
                    "background": "#2F2F2F",
                    "foreground": "#3891A6",
                    "options": {
                        "fetch_sdk_version": true
                    }
                },
                {
                    "type": "node",
                    "style": "diamond",
                    "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}<#7A7A7A> \ue0b3</>",
                    "background": "#2F2F2F",
                    "foreground": "#6CA35E",
                    "options": {
                        "fetch_package_manager": true
                    }
                },
                {
                    "type": "python",
                    "style": "diamond",
                    "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}<#7A7A7A> \ue0b3</>",
                    "background": "#2F2F2F",
                    "foreground": "#96E072"
                },
                {
                    "type": "time",
                    "style": "diamond",
                    "trailing_diamond": "\u2593\ue0c6",
                    "template": " {{ .CurrentDate | date .Format }}<#007ACC> \ue641 </>",
                    "background": "#2F2F2F",
                    "foreground": "#FAFAFA"
                }
            ]
        },
        {
            "type": "prompt",
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "type": "text",
                    "style": "plain",
                    "template": "~#@\u276f",
                    "foreground": "#7A7A7A"
                }
            ]
        },
        {
            "type": "rprompt",
            "alignment": "right",
            "segments": [
                {
                    "type": "text",
                    "style": "plain",
                    "template": " \u276e ",
                    "foreground": "#7A7A7A"
                },
                {
                    "type": "executiontime",
                    "style": "plain",
                    "template": " {{ .FormattedMs }}<#FAFAFA> \uf252 </>",
                    "foreground": "#FFCE5C"
                },
                {
                    "type": "status",
                    "style": "plain",
                    "template": " \uea9f {{ if gt .Code 0 }}{{ .Code }}{{ end }} ",
                    "foreground": "#9FD356",
                    "foreground_templates": [
                        "{{ if gt .Code 0 }}#E84855{{ end }}"
                    ],
                    "options": {
                        "always_enabled": true
                    }
                }
            ]
        }
    ]
}
